{
  "projectName": "Cato_WisdomEngine",
  "version": "0.1.0",
  "search": {
    "defaultLimit": 8,
    "excerptLength": 280,
    "defaultBudget": "L2",
    "minGrounding": 3
  },
  "ask": {
    "defaultTopDocs": 6,
    "outputDirectory": "outputs/memos"
  },
  "compile": {
    "managedBlockStart": "<!-- CATO:BEGIN_MANAGED_BLOCK -->",
    "managedBlockEnd": "<!-- CATO:END_MANAGED_BLOCK -->"
  },
  "paths": {
    "inbox": "inbox/drop_here",
    "selfInbox": "inbox/self",
    "sourceNotes": "wiki/source-notes",
    "drafts": "wiki/drafts",
    "appendReview": "wiki/drafts/append-review",
    "selfRoot": "wiki/self",
    "concepts": "wiki/concepts",
    "entities": "wiki/entities",
    "reportsCanonical": "wiki/reports",
    "briefs": "outputs/briefs",
    "memos": "outputs/memos",
    "reports": "outputs/reports",
    "decks": "outputs/decks",
    "surveillance": "wiki/surveillance",
    "watchProfiles": "wiki/watch-profiles",
    "synthesis": "wiki/synthesis",
    "lint": "logs/lint"
  }
}
